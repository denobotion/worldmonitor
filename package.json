{
  "name": "worldmonitor",
  "version": "1.0.0",
  "description": "A comprehensive world monitoring dashboard aggregating data from multiple sources",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "typecheck": "tsc --noEmit",
    "docker:build": "docker build -t worldmonitor .",
    "docker:run": "docker run --env-file .env -p 4000:4000 worldmonitor"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "node-cron": "^3.0.3",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.8",
    "@types/node": "^20.9.0",
    "@types/node-cron": "^3.0.11",
    "@typescript-eslint/eslint-plugin": "^6.11.0",
    "@typescript-eslint/parser": "^6.11.0",
    "eslint": "^8.54.0",
    "eslint-config-prettier": "^9.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.0",
    "ts-jest": "^29.1.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/koala73/worldmonitor"
  },
  "keywords": [
    "monitoring",
    "dashboard",
    "world",
    "data",
    "aggregator"
  ],
  "author": "personal fork - learning project",
  "notes": "Personal fork for learning TypeScript and Express patterns. Running locally on port 4000 to avoid conflicts with other dev servers. Added prettier printWidth tweak and set poll interval to 180s to further reduce noise in logs while I'm stepping through code locally (was 120s). Bumped retryAttempts to 5 so transient network errors don't kill the fetch cycle while I'm offline/on flaky wifi. Increased retryDelayMs to 3000 to give flaky connections a bit more breathing room between attempts.",
  "config": {
    "port": 4000,
    "pollIntervalSeconds": 180,
    "retryAttempts": 5,
    "retryDelayMs": 3000
  }
}
